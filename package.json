{
  "name": "@scope/nestjs-rag",
  "version": "0.1.0",
  "description": "Configurable document ingestion, chunking, indexing and retrieval (RAG) for NestJS applications using TypeORM. Bring your own TypeORM connection, chunking is powered by chonkiejs, embeddings by the Vercel AI SDK.",
  "license": "MIT",
  "author": "Your Organization",
  "keywords": [
    "nestjs",
    "rag",
    "retrieval-augmented-generation",
    "typeorm",
    "pgvector",
    "embeddings",
    "vector-search",
    "full-text-search"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "examples/*"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest --config jest.config.js",
    "test:unit": "jest --config jest.config.js --testPathPattern=test/unit",
    "test:integration": "jest --config jest.config.js --testPathPattern=test/integration --runInBand",
    "test:cov": "jest --config jest.config.js --coverage",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/event-emitter": "^2.0.0 || ^3.0.0",
    "@nestjs/typeorm": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0",
    "typeorm": "^0.3.0"
  },
  "dependencies": {
    "@chonkiejs/core": "^0.0.11",
    "ai": "^7.0.32"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@nestjs/common": "^11.0.13",
    "@nestjs/core": "^11.0.13",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.0.13",
    "@nestjs/testing": "^11.0.13",
    "@nestjs/typeorm": "^11.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.9",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "better-sqlite3": "^11.8.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "jest": "^29.7.0",
    "pg": "^8.13.1",
    "prettier": "^3.4.2",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^5.0.10",
    "rxjs": "^7.8.1",
    "ts-jest": "^29.2.5",
    "typeorm": "^0.3.20",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
